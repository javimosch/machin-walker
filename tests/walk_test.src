// tests/walk_test.src — the challenge gate, enforced on the COMMITTED artifact
// (no training here; training is ml/walk_train*.src on rbm21).

var g_pass = 0
var g_fail = 0

func check(name, cond) {
	if cond {
		g_pass = g_pass + 1
		println("  PASS  " + name)
	} else {
		g_fail = g_fail + 1
		println("  FAIL  " + name)
	}
}

func main() {
	println("=== the locomotion gate: ml/models/walker.json ===")
	n := net_load("ml/models/walker.json")
	check("artifact loads (tinybrain/v1)", n.tinybrain == 1)
	check("controller topology 13-16-4 (damping senses + learned step-timing)", n.topology[0] == 13 && n.topology[2] == 4)

	// noise-free run
	ep := walk_episode(n, 1500, 0)
	check("covers >= 10m noise-free (got " + str(ep.dist) + "m)", ep.dist >= 10.0)
	check("never falls noise-free", ep.fell == false)
	// the certified gait is a RUN (flight-phase, ~40-55% airborne like real
	// running); sub-8%-flight WALKING is the declared open milestone
	check("gait sanity: airborne fraction < 70% (got " + str(float(ep.flight) / float(ep.ticks)) + ")", float(ep.flight) < 0.70 * float(ep.ticks))
	check("upright: no crouch penalty accumulated (got " + str(ep.lowhip) + ")", ep.lowhip < 12.0)

	// human knees: mean knee flexion must be NEGATIVE (the backwards-knee
	// rig bug walked convincingly — in reverse)
	b := biped_new()
	kneeSum := 0.0
	kph := 0.0
	t := 0
	while t < 600 {
		kph = walk_ctrl_step(n, b, kph, 0.0, 0, t)
		biped_step(b, walk_dt())
		kneeSum = kneeSum + w_joint_angle(b.w, b.jKneeL) + w_joint_angle(b.w, b.jKneeR)
		t = t + 1
	}
	check("knees flex the human way (mean flexion " + str(kneeSum / 1200.0) + " rad, must be < 0)", kneeSum < 0.0)

	// the gate seeds (never used in any training round)
	minD := 1000000.0
	falls := 0
	for _, sd := range []int{999, 777, 12345, 31337, 2026} {
		e := walk_episode(n, 1500, sd)
		if e.dist < minD {
			minD = e.dist
		}
		if e.fell {
			falls = falls + 1
		}
	}
	check("5 held-out noise seeds: all >= 10m (min " + str(minD) + "m)", minD >= 10.0)
	check("5 held-out noise seeds: zero falls", falls == 0)

	println("=== summary ===")
	println("PASS " + str(g_pass) + "   FAIL " + str(g_fail))
	if g_fail > 0 {
		println("THERE WERE FAILURES")
		exit(1)
	}
	println("ALL TESTS PASSED")
}
